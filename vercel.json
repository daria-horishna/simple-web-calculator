{
  "routes": [
    {
      "src": "/ingest/static/(.*)",
      "dest": "https://us-assets.i.posthog.com/static/$1"
    },
    {
      "src": "/ingest/(.*)",
      "dest": "https://us.i.posthog.com/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}